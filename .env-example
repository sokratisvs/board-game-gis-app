# Local: use .env in project root. VM/staging: deploy creates .env from Jenkins params (CLIENT_URLS, REACT_APP_API_BASE_URL).
DB_NAME=
DB_USER=
DB_PASSWORD=
COOKIE_SECRET=
# Optional: cookie domain for staging/production so session works across port (e.g. staging-apps.tail272227.ts.net). Deploy sets this.
# COOKIE_DOMAIN=
# CORS origins. Include exact origin with port when hitting staging (e.g. https://staging-apps.tail272227.ts.net:3000). VM: from params.CLIENT_URLS.
CLIENT_URLS=http://localhost:3000,http://localhost:3001,http://100.124.133.68:3000
# Backend URL for the React build. Local: localhost. VM: from params.REACT_APP_API_BASE_URL.
REACT_APP_API_BASE_URL=http://localhost:4000